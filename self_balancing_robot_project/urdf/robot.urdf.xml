<?xml version="1.0"?>
<robot name="self_balancing_robot">

  <material name="blue">
    <color rgba="0.2 0.4 1.0 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <!-- World anchor for rail joint -->
  <link name="world"/>

  <!-- Rail joint: keeps robot upright, allows forward/backward sliding -->
  <joint name="rail_joint" type="prismatic">
    <parent link="world"/>
    <child link="base_footprint"/>
    <origin xyz="0.0 0.0 0.06" rpy="0.0 0.0 0.0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-10.0" upper="10.0" effort="1000.0" velocity="10.0"/>
    <dynamics damping="0.1"/>
  </joint>

  <link name="base_footprint">
    <visual>
      <geometry><sphere radius="0.01"/></geometry>
      <material name="grey"/>
    </visual>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.25" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Main robot body -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.15 0.1 0.5"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.15 0.1 0.5"/></geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0"
               iyy="0.05" iyz="0.0" izz="0.005"/>
    </inertial>
  </link>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0"
               iyy="0.0005" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.06" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.06" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0"
               iyy="0.0005" iyz="0.0" izz="0.0008"/>
    </inertial>
  </link>

  <!-- Left Wheel Joint -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.1 -0.22" rpy="1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- Right Wheel Joint -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.1 -0.22" rpy="1.5708 0.0 0.0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.05"/>
  </joint>

  <!-- IMU Sensor Link -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.02 0.02 0.02"/></geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0.0 0.2" rpy="0.0 0.0 0.0"/>
  </joint>

  <!-- Wheel friction properties for Gazebo -->
  <gazebo reference="left_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <!-- IMU Sensor Plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <plugin filename="gz-sim-imu-system"
              name="gz::sim::systems::Imu">
      </plugin>
      <topic>/imu</topic>
    </sensor>
  </gazebo>

  <!-- Differential Drive Plugin -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.2</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <max_linear_acceleration>10.0</max_linear_acceleration>
    </plugin>
  </gazebo>

</robot>
